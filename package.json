{
  "name": "proactive-agent",
  "version": "1.0.0",
  "description": "A scheduled AI agent using Claude Agent SDK and Bun",
  "type": "module",
  "scripts": {
    "start": "bun run agent.ts",
    "advanced": "bun run advanced-agent.ts",
    "dev": "bun --watch run agent.ts",
    "test": "bun run tests/test-basic.ts",
    "demo:subagents": "bun run demo/subagents.ts",
    "demo:mcp": "bun run demo/mcp-servers.ts",
    "demo:hooks": "bun run demo/hooks.ts",
    "demo:sessions": "bun run demo/sessions.ts",
    "demo:permissions": "bun run demo/permissions.ts",
    "demo:all": "bun run demo/subagents.ts && bun run demo/mcp-servers.ts && bun run demo/hooks.ts && bun run demo/sessions.ts && bun run demo/permissions.ts",
    "tagging:audit": "bun run tagging-agent.ts audit",
    "tagging:plan": "bun run tagging-agent.ts plan",
    "tagging:execute": "bun run tagging-agent.ts execute",
    "tagging:verify": "bun run tagging-agent.ts verify"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
